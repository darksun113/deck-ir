{
  "name": "deck-ir",
  "version": "0.1.0",
  "description": "Faithfully render PowerPoint .pptx into HTML in pure JS — no PowerPoint, no headless browser.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@9.6.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "COMMERCIAL.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pptx",
    "powerpoint",
    "html",
    "render",
    "parser",
    "presentation",
    "slides",
    "ooxml"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darksun113/deck-ir.git"
  },
  "homepage": "https://github.com/darksun113/deck-ir#readme",
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
